3408L9.2168 15.2305C9.36965 15.1046 9.55583 14.9207 9.90527 14.5713L14.8926 9.58301L11.666 6.35742L6.67871 11.3447ZM16.1963 5.05371C15.3054 4.16304 13.8616 4.16305 12.9707 5.05371L12.6074 5.41602L15.833 8.64258L16.1963 8.2793C17.0869 7.38845 17.0869 5.94456 16.1963 5.05371Z"></path><path d="M4.58301 1.7832C4.72589 1.7832 4.84877 1.88437 4.87695 2.02441C4.99384 2.60873 5.22432 3.11642 5.58398 3.50391C5.94115 3.88854 6.44253 4.172 7.13281 4.28711C7.27713 4.3114 7.38267 4.43665 7.38281 4.58301C7.38281 4.7295 7.27723 4.8546 7.13281 4.87891C6.44249 4.99401 5.94116 5.27746 5.58398 5.66211C5.26908 6.00126 5.05404 6.43267 4.92676 6.92676L4.87695 7.1416C4.84891 7.28183 4.72601 7.38281 4.58301 7.38281C4.44013 7.38267 4.31709 7.28173 4.28906 7.1416C4.17212 6.55728 3.94179 6.04956 3.58203 5.66211C3.22483 5.27757 2.72347 4.99395 2.0332 4.87891C1.88897 4.85446 1.7832 4.72938 1.7832 4.58301C1.78335 4.43673 1.88902 4.3115 2.0332 4.28711C2.72366 4.17203 3.22481 3.88861 3.58203 3.50391C3.94186 3.11638 4.17214 2.60888 4.28906 2.02441L4.30371 1.97363C4.34801 1.86052 4.45804 1.78333 4.58301 1.7832Z"></path></svg>Edit</button></span></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre!"><span><span>ujunwa</span><span><span class="hljs-variable">@DESKTOP</span></span><span>-</span><span><span class="hljs-symbol">xxxx:</span></span><span>~<span class="hljs-variable">$
</span></span></span></code></div></div></pre>
</li>
</ul>
</li>
<li data-start="556" data-end="768">
<p data-start="559" data-end="585">✅ <strong data-start="561" data-end="585">In VS Code terminal:</strong></p>
<ul data-start="589" data-end="768">
<li data-start="589" data-end="660">
<p data-start="591" data-end="660">Once installed, you can <strong data-start="615" data-end="631">open VS Code</strong> → <code data-start="634" data-end="644">Ctrl + ~</code> (open terminal)</p>
</li>
<li data-start="664" data-end="723">
<p data-start="666" data-end="723">Then select <strong data-start="678" data-end="694">Ubuntu (WSL)</strong> as the <strong data-start="702" data-end="722">default terminal</strong>.</p>
</li>
<li data-start="727" data-end="768">
<p data-start="729" data-end="768">Or add it manually in VS Code settings.</p>
</li>
</ul>
</li>
<li data-start="770" data-end="919">
<p data-start="773" data-end="802">✅ <strong data-start="775" data-end="802">From CMD or PowerShell:</strong></p>
