<hr data-start="523" data-end="526">
<h3 data-start="528" data-end="563">📌 <strong data-start="535" data-end="563">2. PowerShell (Optional)</strong></h3>
<ul data-start="564" data-end="671">
<li data-start="564" data-end="671">
<p data-start="566" data-end="582"><strong data-start="566" data-end="582">How to open:</strong></p>
<ol data-start="585" data-end="671">
<li data-start="585" data-end="607">
<p data-start="588" data-end="607">Press <code data-start="594" data-end="607">Windows key</code></p>
</li>
<li data-start="610" data-end="634">
<p data-start="613" data-end="634">Type <strong data-start="618" data-end="634">“powershell”</strong></p>
</li>
<li data-start="637" data-end="668">
<p data-start="640" data-end="668">Click <strong data-start="646" data-end="668">Windows PowerShell</strong></p>
</li>
</ol>
</li>
</ul>
