    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">img</span></span></span><span> </span><span><span class="hljs-attr">src</span></span><span>=</span><span><span class="hljs-string">"images/logo.png"</span></span><span> </span><span><span class="hljs-attr">alt</span></span><span>=</span><span><span class="hljs-string">"TechCon logo"</span></span><span> </span><span><span class="hljs-attr">class</span></span><span>=</span><span><span class="hljs-string">"logo"</span></span><span> /&gt;
    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">nav</span></span></span><span> </span><span><span class="hljs-attr">class</span></span><span>=</span><span><span class="hljs-string">"nav"</span></span><span>&gt;
      </span><span><span class="hljs-tag">&lt;<span class="hljs-name">a</span></span></span><span> </span><span><span class="hljs-attr">href</span></span><span>=</span><span><span class="hljs-string">"#"</span></span><span>&gt;Home</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">a</span></span></span><span>&gt;
      </span><span><span class="hljs-tag">&lt;<span class="hljs-name">a</span></span></span><span> </span><span><span class="hljs-attr">href</span></span><span>=</span><span><span class="hljs-string">"#"</span></span><span>&gt;About</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">a</span></span></span><span>&gt;
      </span><span><span class="hljs-tag">&lt;<span class="hljs-name">a</span></span></span><span> </span><span><span class="hljs-attr">href</span></span><span>=</span><span><span class="hljs-string">"#"</span></span><span>&gt;Schedule</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">a</span></span></span><span>&gt;
      </span><span><span class="hljs-tag">&lt;<span class="hljs-name">a</span></span></span><span> </span><span><span class="hljs-attr">href</span></span><span>=</span><span><span class="hljs-string">"#"</span></span><span>&gt;Register</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">a</span></span></span><span>&gt;
      </span><span><span class="hljs-tag">&lt;<span class="hljs-name">a</span></span></span><span> </span><span><span class="hljs-attr">href</span></span><span>=</span><span><span class="hljs-string">"#"</span></span><span>&gt;Contact</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">a</span></span></span><span>&gt;
    </span><span><span class="hljs-tag">&lt;/<span class="hljs-name">nav</span></span></span><span>&gt;
  </span><span><span class="hljs-tag">&lt;/<span class="hljs-name">div</span></span></span><span>&gt;
</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">header</span></span></span><span>&gt;

</span><span><span class="hljs-tag">&lt;<span class="hljs-name">section</span></span></span><span> </span><span><span class="hljs-attr">class</span></span><span>=</span><span><span class="hljs-string">"banner"</span></span><span>&gt;
  </span><span><span class="hljs-tag">&lt;<span class="hljs-name">div</span></span></span><span> </span><span><span class="hljs-attr">class</span></span><span>=</span><span><span class="hljs-string">"container"</span></span><span>&gt;
    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">h1</span></span></span><span>&gt;Welcome to TechCon 2024</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">h1</span></span></span><span>&gt;
    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">p</span></span></span><span>&gt;Join leaders in tech for innovation and inspiration!</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span></span></span><span>&gt;
    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">button</span></span></span><span> </span><span><span class="hljs-attr">class</span></span><span>=</span><span><span class="hljs-string">"cta"</span></span><span>&gt;Register Now</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">button</span></span></span><span>&gt;
  </span><span><span class="hljs-tag">&lt;/<span class="hljs-name">div</span></span></span><span>&gt;
</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">section</span></span></span><span>&gt;
</span></span></code></div></div></pre>
<p data-start="903" data-end="911">🟨 Note:</p>
<ul data-start="912" data-end="1029">
<li data-start="912" data-end="979">
<p data-start="914" data-end="979">Save your images in a folder called <code data-start="950" data-end="958">images</code> inside your project.</p>
</li>
<li data-start="980" data-end="1029">
<p data-start="982" data-end="1029">Example: <code data-start="991" data-end="1008">images/logo.png</code>, <code data-start="1010" data-end="1029">images/banner.jpg</code></p>
</li>
</ul>
<hr data-start="1031" data-end="1034">
<h2 data-start="1036" data-end="1070">✅ 2. CSS Styling (<code data-start="1057" data-end="1069">styles.css</code>)</h2>
<p data-start="1072" data-end="1157">Here’s what to put in your <code data-start="1099" data-end="1111">styles.css</code> file to complete <strong data-start="1129" data-end="1156">header + banner styling</strong>:</p>
<pre class="overflow-visible!" data-start="1159" data-end="2289"><div class="contain-inline-size rounded-2xl relative bg-token-sidebar-surface-primary"><div class="flex items-center text-token-text-secondary px-4 py-2 text-xs font-sans justify-between h-9 bg-token-sidebar-surface-primary select-none rounded-t-2xl">css</div><div class="sticky top-9"><div class="absolute end-0 bottom-0 flex h-9 items-center pe-2"><div class="bg-token-bg-elevated-secondary text-token-text-secondary flex items-center gap-4 rounded-sm px-2 font-sans text-xs"><button class="flex gap-1 items-center select-none py-1" aria-label="Copy"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="icon-xs"><path d="M12.668 10.667C12.668 9.95614 12.668 9.46258 12.6367 9.0791C12.6137 8.79732 12.5758 8.60761 12.5244 8.46387L12.4688 8.33399C12.3148 8.03193 12.0803 7.77885 11.793 7.60254L11.666 7.53125C11.508 7.45087 11.2963 7.39395 10.9209 7.36328C10.5374 7.33197 10.0439 7.33203 9.33301 7.33203H6.5C5.78896 7.33203 5.29563 7.33195 4.91211 7.36328C4.63016 7.38632 4.44065 7.42413 4.29688 7.47559L4.16699 7.53125C3.86488 7.68518 3.61186 7.9196 3.43555 8.20703L3.36524 8.33399C3.28478 8.49198 3.22795 8.70352 3.19727 9.0791C3.16595 9.46259 3.16504 9.95611 3.16504 10.667V13.5C3.16504 14.211 3.16593 14.7044 3.19727 15.0879C3.22797 15.4636 3.28473 15.675 3.36524 15.833L3.43555 15.959C3.61186 16.2466 3.86474 16.4807 4.16699 16.6348L4.29688 16.6914C4.44063 16.7428 4.63025 16.7797 4.91211 16.8027C5.29563 16.8341 5.78896 16.835 6.5 16.835H9.33301C10.0439 16.835 10.5374 16.8341 10.9209 16.8027C11.2965 16.772 11.508 16.7152 11.666 16.6348L11.793 16.5645C12.0804 16.3881 12.3148 16.1351 12.4688 15.833L12.5244 15.7031C12.5759 15.5594 12.6137 15.3698 12.6367 15.0879C12.6681 14.7044 12.668 14.211 12.668 13.5V10.667ZM13.998 12.665C14.4528 12.6634 14.8011 12.6602 15.0879 12.6367C15.4635 12.606 15.675 12.5492 15.833 12.4688L15.959 12.3975C16.2466 12.2211 16.4808 11.9682 16.