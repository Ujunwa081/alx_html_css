.3408L9.2168 15.2305C9.36965 15.1046 9.55583 14.9207 9.90527 14.5713L14.8926 9.58301L11.666 6.35742L6.67871 11.3447ZM16.1963 5.05371C15.3054 4.16304 13.8616 4.16305 12.9707 5.05371L12.6074 5.41602L15.833 8.64258L16.1963 8.2793C17.0869 7.38845 17.0869 5.94456 16.1963 5.05371Z"></path><path d="M4.58301 1.7832C4.72589 1.7832 4.84877 1.88437 4.87695 2.02441C4.99384 2.60873 5.22432 3.11642 5.58398 3.50391C5.94115 3.88854 6.44253 4.172 7.13281 4.28711C7.27713 4.3114 7.38267 4.43665 7.38281 4.58301C7.38281 4.7295 7.27723 4.8546 7.13281 4.87891C6.44249 4.99401 5.94116 5.27746 5.58398 5.66211C5.26908 6.00126 5.05404 6.43267 4.92676 6.92676L4.87695 7.1416C4.84891 7.28183 4.72601 7.38281 4.58301 7.38281C4.44013 7.38267 4.31709 7.28173 4.28906 7.1416C4.17212 6.55728 3.94179 6.04956 3.58203 5.66211C3.22483 5.27757 2.72347 4.99395 2.0332 4.87891C1.88897 4.85446 1.7832 4.72938 1.7832 4.58301C1.78335 4.43673 1.88902 4.3115 2.0332 4.28711C2.72366 4.17203 3.22481 3.88861 3.58203 3.50391C3.94186 3.11638 4.17214 2.60888 4.28906 2.02441L4.30371 1.97363C4.34801 1.86052 4.45804 1.78333 4.58301 1.7832Z"></path></svg>Edit</button></span></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-css"><span><span><span class="hljs-comment">/* General resets */</span></span><span>
* {
    </span><span><span class="hljs-attribute">margin</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
    </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
    </span><span><span class="hljs-attribute">box-sizing</span></span><span>: border-box;
}

</span><span><span class="hljs-selector-tag">body</span></span><span> {
    </span><span><span class="hljs-attribute">font-family</span></span><span>: </span><span><span class="hljs-string">'Source Sans Pro'</span></span><span>, sans-serif;
    </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#333</span></span><span>;
}

</span><span><span class="hljs-comment">/* Header styles */</span></span><span>
</span><span><span class="hljs-selector-class">.site-header</span></span><span> {
    </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#0a0a23</span></span><span>; </span><span><span class="hljs-comment">/* Example color from Figma */</span></span><span>
    </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span> </span><span><span class="hljs-number">0</span></span><span>;
}

</span><span><span class="hljs-selector-class">.site-header</span></span><span> </span><span><span class="hljs-selector-class">.container</span></span><span> {
    </span><span><span class="hljs-attribute">display</span></span><span>: flex;
    </span><span><span class="hljs-attribute">justify-content</span></span><span>: space-between;
    </span><span><span class="hljs-attribute">align-items</span></span><span>: center;
    </span><span><span class="hljs-attribute">max-width</span></span><span>: </span><span><span class="hljs-number">1200px</span></span><span>;
    </span><span><span class="hljs-attribute">margin</span></span><span>: </span><span><span class="hljs-number">0</span></span><span> auto;
    </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">0</span></span><span> </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.logo</span></span><span> {
    </span><span><span class="hljs-attribute">height</span></span><span>: </span><span><span class="hljs-number">50px</span></span><span>; </span><span><span class="hljs-comment">/* or width depending on Figma */</span></span><span>
}

</span><span><span class="hljs-selector-class">.site-nav</span></span><span> </span><span><span class="hljs-selector-tag">a</span></span><span> {
    </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#ffffff</span></span><span>;
    </span><span><span class="hljs-attribute">text-decoration</span></span><span>: none;
    </span><span><span class="hljs-attribute">margin-left</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
    </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">16px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.site-nav</span></span><span> </span><span><span class="hljs-selector-tag">a</span></span><span><span class="hljs-selector-pseudo">:hover</span></span><span> {
    </span><span><span class="hljs-attribute">text-decoration</span></span><span>: underline;
}

</span><span><span class="hljs-comment">/* Banner section */</span></span><span>
</span><span><span class="hljs-selector-class">.banner</span></span><span> {
    </span><span><span class="hljs-attribute">background-image</span></span><span>: </span><span><span class="hljs-built_in">url</span></span><span>(</span><span><span class="hljs-string">'images/banner.jpg'</span></span><span>); </span><span><span class="hljs-comment">/* Replace with real Figma image path */</span></span><span>
    </span><span><span class="hljs-attribute">background-size</span></span><span>: cover;
    </span><span><span class="hljs-attribute">background-position</span></span><span>: center;
    </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
    </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">100px</span></span><span> </span><span><span class="hljs-number">20px</span></span><span>;
    </span><span><span class="hljs-attribute">text-align</span></span><span>: center;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">h1</span></span><span> {
    </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">48px</span></span><span>;
    </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">p</span></span><span> {
    </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
    </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">30px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">button</span></span><span> {
    </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#ff6b6b</span></span><span>;
    </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
    </span><span><span class="hljs-attribute">border</span></span><span>: none;
    </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">12px</span></span><span> </span><span><span class="hljs-number">30px</span></span><span>;
    </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">16px</span></span><span>;
    </span><span><span class="hljs-attribute">border-radius</span></span><span>: </span><span><span class="hljs-number">5px</span></span><span>;
    </span><span><span class="hljs-attribute">cursor</span></span><span>: pointer;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">button</span></span><span><span class="hljs-selector-pseudo">:hover</span></span><span> {
    </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#e65a5a</span></span><span>;
}
</span></span></code></div></div></pre>
<hr data-start="2473" data-end="2476">
<h2 data-start="2478" data-end="2537">✅ <strong data-start="2483" data-end="2537">3️⃣ What You Must Change/Check Based on Your Figma</strong></h2>
<ul data-start="2538" data-end="2770">
<li data-start="2538" data-end="2616">
<p data-start="2540" data-end="2616"><code data-start="2540" data-end="2558">background-color</code>, <code data-start="2560" data-end="2571">font-size</code>, spacing → <strong data-start="2583" data-end="2616">Check Figma for exact numbers</strong></p>
</li>
<li data-start="2617" data-end="2694">
<p data-start="2619" data-end="2694"><code data-start="2619" data-end="2636">images/logo.png</code> → Upload your logo image to <code data-start="2665" data-end="2674">images/</code> folder in your repo</p>
</li>
<li data-start="2695" data-end="2770">
<p data-start="2697" data-end="2770"><code data-start="2697" data-end="2716">images/banner.jpg</code> → Upload the banner image to <code data-start="2746" data-end="2755">images/</code> folder as well</p>
</li>
</ul>
<hr data-start="2772" data-end="2775">
