    </span><span><span class="hljs-tag">&lt;<span class="hljs-name">main</span></span></span><span>&gt;
        </span><span><span class="hljs-tag">&lt;<span class="hljs-name">section</span></span></span><span>&gt;
            </span><span><span class="hljs-tag">&lt;<span class="hljs-name">h2</span></span></span><span>&gt;Welcome to TechCon 2024!</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">h2</span></span></span><span>&gt;
            </span><span><span class="hljs-tag">&lt;<span class="hljs-name">p</span></span></span><span>&gt;Join us for an exciting conference on emerging technologies, innovation, and networking with industry leaders.</span><span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span></span></span><span>&gt;
            </span><span><span class="hljs-tag">&lt;<span class="hljs-name">video</span></span></span><span> </span><span><span class="hljs-attr">controls</span></span><span> </span><span><span class="hljs-attr">width</span></span><span>=</span><span><span class="hljs-string">"640"</span></span><span> </span><span><span class="hljs-attr">height</span></span><span>=</span><span><span class="hljs-string">"360"</span></span><span>&gt;
                </span><span><span class="hljs-tag">&lt;<span class="hljs-name">source</span></span></span><span> </span><span><span class="hljs-attr">src</span></span><span>=</span><span><span class="hljs-string">"promo.mp4"</span></span><span> </span><span><span class="hljs-attr">type</span></span><span>=</span><span><span class="hljs-string">"video/mp4"</span></span><span>&gt;
                Your browser does not support the video tag.
            </span><span><span class="hljs-tag">&lt;/<span class="hljs-name">video</span></span></span><span>&gt;
        </span><span><span class="hljs-tag">&lt;/<span class="hljs-name">section</span></span></span><span>&gt;
