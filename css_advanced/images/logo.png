1057 5.53708 6.00551 6.00391 6.00391C6.00551 5.53708 6.01057 5.14051 6.03809 4.80371C6.0755 4.34588 6.15483 3.94012 6.34668 3.56348L6.46875 3.34473C6.77282 2.84912 7.20856 2.44514 7.72949 2.17969L7.87207 2.11328C8.20855 1.96886 8.56979 1.90385 8.9707 1.87109C9.42091 1.83432 9.978 1.83496 10.667 1.83496H13.5C14.1891 1.83496 14.746 1.83431 15.1963 1.87109C15.6541 1.90851 16.0599 1.98788 16.4365 2.17969L16.6553 2.30176C17.151 2.60585 17.5548 3.04244 17.8203 3.56348L17.8867 3.70606C18.031 4.04235 18.0962 4.40306 18.1289 4.80371C18.1657 5.25395 18.165 5.81091 18.165 6.5V9.33301Z"></path></svg>Copy</button><span class="" data-state="closed"><button class="flex items-center gap-1 py-1 select-none"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="icon-xs"><path d="M12.0303 4.11328C13.4406 2.70317 15.7275 2.70305 17.1377 4.11328C18.5474 5.52355 18.5476 7.81057 17.1377 9.2207L10.8457 15.5117C10.522 15.8354 10.2868 16.0723 10.0547 16.2627L9.82031 16.4395C9.61539 16.5794 9.39783 16.7003 9.1709 16.7998L8.94141 16.8916C8.75976 16.9582 8.57206 17.0072 8.35547 17.0518L7.59082 17.1865L5.19727 17.5859C5.05455 17.6097 4.90286 17.6358 4.77441 17.6455C4.67576 17.653 4.54196 17.6555 4.39648 17.6201L4.24707 17.5703C4.02415 17.4746 3.84119 17.3068 3.72559 17.0957L3.67969 17.0029C3.59322 16.8013 3.59553 16.6073 3.60547 16.4756C3.61519 16.3473 3.6403 16.1963 3.66406 16.0537L4.06348 13.6602C4.1638 13.0582 4.22517 12.6732 4.3584 12.3096L4.45117 12.0791C4.55073 11.8521 4.67152 11.6346 4.81152 11.4297L4.9873 11.1953C5.17772 10.9632 5.4146 10.728 5.73828 10.4043L12.0303 4.11328ZM6.67871 11.3447C6.32926 11.6942 6.14542 11.8803 6.01953 12.0332L5.90918 12.1797C5.81574 12.3165 5.73539 12.4618 5.66895 12.6133L5.60742 12.7666C5.52668 12.9869 5.48332 13.229 5.375 13.8789L4.97656 16.2725L4.97559 16.2744H4.97852L7.37207 15.875L8.08887 15.749C8.25765 15.7147 8.37336 15.6839 8.4834 15.6436L8.63672 15.5811C8.78817 15.5146 8.93356 15.4342 9.07031 15.3408L9.2168 15.2305C9.36965 15.1046 9.55583 14.9207 9.90527 14.5713L14.8926 9.58301L11.666 6.35742L6.67871 11.3447ZM16.1963 5.05371C15.3054 4.16304 13.8616 4.16305 12.9707 5.05371L12.6074 5.41602L15.833 8.64258L16.1963 8.2793C17.0869 7.38845 17.0869 5.94456 16.1963 5.05371Z"></path><path d="M4.58301 1.7832C4.72589 1.7832 4.84877 1.88437 4.87695 2.02441C4.99384 2.60873 5.22432 3.11642 5.58398 3.50391C5.94115 3.88854 6.44253 4.172 7.13281 4.28711C7.27713 4.3114 7.38267 4.43665 7.38281 4.58301C7.38281 4.7295 7.27723 4.8546 7.13281 4.87891C6.44249 4.99401 5.94116 5.27746 5.58398 5.66211C5.26908 6.00126 5.05404 6.43267 4.92676 6.92676L4.87695 7.1416C4.84891 7.28183 4.72601 7.38281 4.58301 7.38281C4.44013 7.38267 4.31709 7.28173 4.28906 7.1416C4.17212 6.55728 3.94179 6.04956 3.58203 5.66211C3.22483 5.27757 2.72347 4.99395 2.0332 4.87891C1.88897 4.85446 1.7832 4.72938 1.7832 4.58301C1.78335 4.43673 1.88902 4.3115 2.0332 4.28711C2.72366 4.17203 3.22481 3.88861 3.58203 3.50391C3.94186 3.11638 4.17214 2.60888 4.28906 2.02441L4.30371 1.97363C4.34801 1.86052 4.45804 1.78333 4.58301 1.7832Z"></path></svg>Edit</button></span></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-css"><span><span><span class="hljs-comment">/* RESET */</span></span><span>
* {
  </span><span><span class="hljs-attribute">margin</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
  </span><span><span class="hljs-attribute">box-sizing</span></span><span>: border-box;
}

</span><span><span class="hljs-selector-tag">body</span></span><span> {
  </span><span><span class="hljs-attribute">font-family</span></span><span>: </span><span><span class="hljs-string">'Source Sans Pro'</span></span><span>, sans-serif;
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#333</span></span><span>;
}

</span><span><span class="hljs-comment">/* HEADER */</span></span><span>
</span><span><span class="hljs-selector-class">.header</span></span><span> {
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#0a0a23</span></span><span>; </span><span><span class="hljs-comment">/* Replace with real Figma color */</span></span><span>
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span> </span><span><span class="hljs-number">0</span></span><span>;
}

</span><span><span class="hljs-selector-class">.header</span></span><span> </span><span><span class="hljs-selector-class">.container</span></span><span> {
  </span><span><span class="hljs-attribute">max-width</span></span><span>: </span><span><span class="hljs-number">1200px</span></span><span>;
  </span><span><span class="hljs-attribute">margin</span></span><span>: </span><span><span class="hljs-number">0</span></span><span> auto;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">0</span></span><span> </span><span><span class="hljs-number">20px</span></span><span>;
  </span><span><span class="hljs-attribute">display</span></span><span>: flex;
  </span><span><span class="hljs-attribute">justify-content</span></span><span>: space-between;
  </span><span><span class="hljs-attribute">align-items</span></span><span>: center;
}

</span><span><span class="hljs-selector-class">.logo</span></span><span> {
  </span><span><span class="hljs-attribute">width</span></span><span>: </span><span><span class="hljs-number">120px</span></span><span>; </span><span><span class="hljs-comment">/* adjust based on Figma */</span></span><span>
}

</span><span><span class="hljs-selector-class">.nav</span></span><span> </span><span><span class="hljs-selector-tag">a</span></span><span> {
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
  </span><span><span class="hljs-attribute">text-decoration</span></span><span>: none;
  </span><span><span class="hljs-attribute">margin-left</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">16px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.nav</span></span><span> </span><span><span class="hljs-selector-tag">a</span></span><span><span class="hljs-selector-pseudo">:hover</span></span><span> {
  </span><span><span class="hljs-attribute">text-decoration</span></span><span>: underline;
}

</span><span><span class="hljs-comment">/* BANNER */</span></span><span>
</span><span><span class="hljs-selector-class">.banner</span></span><span> {
  </span><span><span class="hljs-attribute">background-image</span></span><span>: </span><span><span class="hljs-built_in">url</span></span><span>(</span><span><span class="hljs-string">"images/banner.jpg"</span></span><span>);
  </span><span><span class="hljs-attribute">background-size</span></span><span>: cover;
  </span><span><span class="hljs-attribute">background-position</span></span><span>: center;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">100px</span></span><span> </span><span><span class="hljs-number">20px</span></span><span>;
  </span><span><span class="hljs-attribute">text-align</span></span><span>: center;
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">h1</span></span><span> {
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">48px</span></span><span>;
  </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">p</span></span><span> {
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
  </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">30px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-class">.cta</span></span><span> {
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#ff6b6b</span></span><span>;
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
  </span><span><span class="hljs-attribute">border</span></span><span>: none;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">12px</span></span><span> </span><span><span class="hljs-number">30px</span></span><span>;
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">16px</span></span><span>;
  </span><span><span class="hljs-attribute">border-radius</span></span><span>: </span><span><span class="hljs-number">5px</span></span><span>;
  </span><span><span class="hljs-attribute">cursor</span></span><span>: pointer;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-class">.cta</span></span><span><span class="hljs-selector-pseudo">:hover</span></span><span> {
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#e65a5a</span></span><span>;
}
</span></span></code></div></div></pre>
<hr data-start="2291" data-end="2294">
<h2 data-start="2296" data-end="2316">✅ 3. Check Images</h2>
<p data-start="2318" data-end="2365">Make sure you have these in your GitHub folder:</p>
