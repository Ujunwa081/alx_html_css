.3408L9.2168 15.2305C9.36965 15.1046 9.55583 14.9207 9.90527 14.5713L14.8926 9.58301L11.666 6.35742L6.67871 11.3447ZM16.1963 5.05371C15.3054 4.16304 13.8616 4.16305 12.9707 5.05371L12.6074 5.41602L15.833 8.64258L16.1963 8.2793C17.0869 7.38845 17.0869 5.94456 16.1963 5.05371Z"></path><path d="M4.58301 1.7832C4.72589 1.7832 4.84877 1.88437 4.87695 2.02441C4.99384 2.60873 5.22432 3.11642 5.58398 3.50391C5.94115 3.88854 6.44253 4.172 7.13281 4.28711C7.27713 4.3114 7.38267 4.43665 7.38281 4.58301C7.38281 4.7295 7.27723 4.8546 7.13281 4.87891C6.44249 4.99401 5.94116 5.27746 5.58398 5.66211C5.26908 6.00126 5.05404 6.43267 4.92676 6.92676L4.87695 7.1416C4.84891 7.28183 4.72601 7.38281 4.58301 7.38281C4.44013 7.38267 4.31709 7.28173 4.28906 7.1416C4.17212 6.55728 3.94179 6.04956 3.58203 5.66211C3.22483 5.27757 2.72347 4.99395 2.0332 4.87891C1.88897 4.85446 1.7832 4.72938 1.7832 4.58301C1.78335 4.43673 1.88902 4.3115 2.0332 4.28711C2.72366 4.17203 3.22481 3.88861 3.58203 3.50391C3.94186 3.11638 4.17214 2.60888 4.28906 2.02441L4.30371 1.97363C4.34801 1.86052 4.45804 1.78333 4.58301 1.7832Z"></path></svg>Edit</button></span></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-css"><span><span><span class="hljs-comment">/* Reset styles */</span></span><span>
* {
  </span><span><span class="hljs-attribute">margin</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">0</span></span><span>;
  </span><span><span class="hljs-attribute">box-sizing</span></span><span>: border-box;
}

</span><span><span class="hljs-selector-tag">body</span></span><span> {
  </span><span><span class="hljs-attribute">font-family</span></span><span>: sans-serif;
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#333</span></span><span>;
}

</span><span><span class="hljs-comment">/* Header styling */</span></span><span>
</span><span><span class="hljs-selector-class">.header</span></span><span> {
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#0a0a23</span></span><span>;  </span><span><span class="hljs-comment">/* Dark blue header */</span></span><span>
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
  </span><span><span class="hljs-attribute">display</span></span><span>: flex;
  </span><span><span class="hljs-attribute">justify-content</span></span><span>: space-between;
  </span><span><span class="hljs-attribute">align-items</span></span><span>: center;
}

</span><span><span class="hljs-selector-class">.logo</span></span><span> {
  </span><span><span class="hljs-attribute">width</span></span><span>: </span><span><span class="hljs-number">120px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.nav</span></span><span> </span><span><span class="hljs-selector-tag">a</span></span><span> {
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
  </span><span><span class="hljs-attribute">text-decoration</span></span><span>: none;
  </span><span><span class="hljs-attribute">margin-left</span></span><span>: </span><span><span class="hljs-number">15px</span></span><span>;
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">16px</span></span><span>;
}

</span><span><span class="hljs-comment">/* Banner styling */</span></span><span>
</span><span><span class="hljs-selector-class">.banner</span></span><span> {
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#333</span></span><span>;  </span><span><span class="hljs-comment">/* You will replace this with a real image later */</span></span><span>
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
  </span><span><span class="hljs-attribute">text-align</span></span><span>: center;
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">100px</span></span><span> </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">h1</span></span><span> {
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">40px</span></span><span>;
  </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">p</span></span><span> {
  </span><span><span class="hljs-attribute">font-size</span></span><span>: </span><span><span class="hljs-number">18px</span></span><span>;
  </span><span><span class="hljs-attribute">margin-bottom</span></span><span>: </span><span><span class="hljs-number">20px</span></span><span>;
}

</span><span><span class="hljs-selector-class">.banner</span></span><span> </span><span><span class="hljs-selector-tag">button</span></span><span> {
  </span><span><span class="hljs-attribute">padding</span></span><span>: </span><span><span class="hljs-number">10px</span></span><span> </span><span><span class="hljs-number">25px</span></span><span>;
  </span><span><span class="hljs-attribute">background-color</span></span><span>: </span><span><span class="hljs-number">#ff6b6b</span></span><span>;
  </span><span><span class="hljs-attribute">color</span></span><span>: </span><span><span class="hljs-number">#fff</span></span><span>;
  </span><span><span class="hljs-attribute">border</span></span><span>: none;
  </span><span><span class="hljs-attribute">border-radius</span></span><span>: </span><span><span class="hljs-number">5px</span></span><span>;
  </span><span><span class="hljs-attribute">cursor</span></span><span>: pointer;
}
</span></span></code></div></div></pre>
<hr data-start="2740" data-end="2743">
<h3 data-start="2745" data-end="2787">✅ <strong data-start="2751" data-end="2787">Step 4: Add Images (if you have)</strong></h3>
<ul data-start="2788" data-end="3014">
<li data-start="2788" data-end="2863">
<p data-start="2790" data-end="2863">Inside your <code data-start="2802" data-end="2817">css_advanced/</code> folder → create a folder called <strong data-start="2850" data-end="2863"><code data-start="2852" data-end="2861">images/</code></strong></p>
</li>
<li data-start="2864" data-end="2931">
<p data-start="2866" data-end="2931">Inside <strong data-start="2873" data-end="2886"><code data-start="2875" data-end="2884">images/</code></strong>, place a logo image → name it <strong data-start="2917" data-end="2931"><code data-start="2919" data-end="2929">logo.png</code></strong></p>
</li>
<li data-start="2932" data-end="3014">
<p data-start="2934" data-end="3014">For now → leave the banner <strong data-start="2961" data-end="2979">with the color</strong>, or use a placeholder image later.</p>
</li>
</ul>
<hr data-start="3016" data-end="3019">
<h3 data-start="3021" data-end="3047">✅ <strong data-start="3027" data-end="3047">Step 5: Save All</strong></h3>
<hr data-start="3049" data-end="3052">
<h3 data-start="3054" data-end="3086">✅ <strong data-start="3060" data-end="3086">Step 6: Push to GitHub</strong></h3>
<p data-start="3087" data-end="3132">Open your terminal in VS Code or Windows CMD:</p>
